# Surreal Numbers

```elixir
Mix.install([
  {:ets, "~> 0.9.0"},
  {:eternal, "~> 1.2"}
])

require Logger

defmodule Surreal.Guards do
  defguard is_set(surreals) when is_list(surreals)

  defguard is_surreal(surreal) when is_tuple(surreal) and tuple_size(surreal) == 2
end

defmodule Surreal.Cache do
  @name __MODULE__

  def init() do
    ETS.KeyValueSet.new!(name: @name, protection: :public)
  end

  defp cache() do
    ETS.KeyValueSet.wrap_existing!(@name)
  end

  def fetch(key) do
    ETS.KeyValueSet.get!(cache(), key)
  end

  def store(key, value) do
    ETS.KeyValueSet.put!(cache(), key, value)
  end

  @spec try(any, any) :: any
  def try(key, value_fun) do
    cached = fetch(key)

    if cached do
      cached
    else
      value = value_fun.()
      store(key, value)
      value
    end
  end
end

Surreal.Cache.init()
```

